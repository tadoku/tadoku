load(
  './../k8s/dev/config/Tiltfile',
  'dev_build_platform',
  'dev_buildx_builder',
  'dev_buildx_registry_insecure',
  'is_shared_cluster',
  'render_template',
)

def _sh_quote(value):
  return "'" + value.replace("'", "'\"'\"'") + "'"

def _buildx_output():
  output = 'type=image,name=$EXPECTED_REF,push=true,oci-mediatypes=true'
  if dev_buildx_registry_insecure():
    output += ',registry.insecure=true'
  return output

def _buildx_setup_command():
  builder = _sh_quote(dev_buildx_builder())
  return (
    'docker buildx inspect {builder} >/dev/null 2>&1 || ' +
    'docker buildx create --name {builder} --driver docker-container >/dev/null; ' +
    'docker buildx inspect --bootstrap {builder} >/dev/null; '
  ).format(builder=builder)

def frontend_build(image, project_name, package_trigger):
  if is_shared_cluster():
    command = (
      _buildx_setup_command() +
      'docker buildx build --builder {builder} --platform {platform} -f ./Dockerfile.dev ' +
      '--build-arg PROJECT_NAME={project_name} ' +
      '--provenance=false --sbom=false ' +
      '--output {output} .'
    ).format(
      builder=_sh_quote(dev_buildx_builder()),
      platform=_sh_quote(dev_build_platform()),
      project_name=project_name,
      output=_buildx_output(),
    )
  else:
    command = (
      'docker build --platform {platform} -f ./Dockerfile.dev --build-arg PROJECT_NAME={project_name} -t $EXPECTED_REF .'
    ).format(
      platform=_sh_quote(dev_build_platform()),
      project_name=project_name,
    )

  package_triggers = [
    package_trigger,
    './packages/ui/package.json',
    './package.json',
    './pnpm-lock.yaml',
    './pnpm-workspace.yaml',
  ]

  custom_build(
    image,
    command=command,
    deps=[
      './Dockerfile.dev',
      './package.json',
      './pnpm-lock.yaml',
      './pnpm-workspace.yaml',
      package_trigger,
      './apps/%s' % project_name,
      './packages',
    ],
    disable_push=True,
    skips_local_docker=is_shared_cluster(),
    live_update=[
      sync('./apps/%s' % project_name, '/app/apps/%s' % project_name),
      sync('./packages', '/app/packages'),
      sync('./package.json', '/app/package.json'),
      sync('./pnpm-lock.yaml', '/app/pnpm-lock.yaml'),
      sync('./pnpm-workspace.yaml', '/app/pnpm-workspace.yaml'),
      run('pnpm -r install', trigger=package_triggers),
    ],
    entrypoint='pnpm run %s' % project_name,
  )

# webv2
frontend_webv2 = render_template('frontend/apps/webv2/deployments/frontend-webv2.yaml', '.tilt/rendered/frontend/apps/webv2/deployments/frontend-webv2.yaml')
k8s_yaml(frontend_webv2)
k8s_resource("frontend-webv2", labels=["frontend"])
frontend_build('frontend-webv2', 'webv2', './apps/webv2/package.json')

# auth
frontend_auth = render_template('frontend/apps/auth/deployments/frontend-auth.yaml', '.tilt/rendered/frontend/apps/auth/deployments/frontend-auth.yaml')
k8s_yaml(frontend_auth)
k8s_resource("frontend-auth", labels=["auth"])
frontend_build('frontend-auth', 'auth', './apps/auth/package.json')

# admin
frontend_admin = render_template('frontend/apps/admin/deployments/frontend-admin.yaml', '.tilt/rendered/frontend/apps/admin/deployments/frontend-admin.yaml')
k8s_yaml(frontend_admin)
k8s_resource("frontend-admin", labels=["frontend"])
frontend_build('frontend-admin', 'admin', './apps/admin/package.json')
